{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A fashion product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["pants", "shirt", "basic-tops"] },
        "images": { "type": "array", "items": { "type": "string" } },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "gender": { "type": "string", "enum": ["man", "woman", "unisex"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "images", "sizes"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "items": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "size": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "phone", "address", "items", "total", "status"]
    },
    "Admin": {
      "title": "Admin",
      "description": "An administrative user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "User": {
      "title": "User",
      "description": "A customer profile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "A product saved by a user",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId"]
    },
    "Review": {
      "title": "Review",
      "description": "A product review from a customer",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["rating", "comment"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Notification sent to a customer",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["phone", "message"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "landingVideoUrl": { "type": "string" },
        "logoUrl": { "type": "string" },
        "socialLinks": { 
          "type": "object",
          "properties": {
            "instagram": { "type": "string" },
            "facebook": { "type": "string" },
            "twitter": { "type": "string" },
            "whatsapp": { "type": "string" }
          }
        },
        "contactEmail": { "type": "string" },
        "automationEmail": { "type": "string" },
        "adminEmails": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of store products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/admins/{adminUid}": {
      "schema": "Admin",
      "description": "Collection of administrators"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System notifications for orders"
    },
    "/settings/{settingsId}": {
      "schema": "Settings",
      "description": "Global app settings"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/users/{userId}/wishlist/{productId}": {
      "schema": "WishlistItem",
      "description": "User's saved products"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    }
  }
}
