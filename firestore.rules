rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email_verified == true && (
        request.auth.token.email == "motaem23y@gmail.com" ||
        (exists(/databases/$(database)/documents/settings/global) && 
         request.auth.token.email in get(/databases/$(database)/documents/settings/global).data.adminEmails) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validations ---

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.price is number && data.price > 0 &&
             data.category in ['pants', 'shirt', 'basic-tops'] &&
             data.images is list && data.images.size() > 0 &&
             data.sizes is list && data.sizes.size() > 0 &&
             data.gender in ['man', 'woman', 'unisex'] &&
             data.updatedAt == request.time;
    }

    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 &&
             data.phone is string && data.phone.size() >= 8 &&
             data.address is string && data.address.size() > 0 &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'confirmed', 'shipped', 'delivered', 'cancelled'];
    }

    function isValidUser(data) {
      return data.email is string && (data.role == 'user' || data.role == 'admin') &&
             (data.displayName == null || data.displayName is string) &&
             (data.photoURL == null || data.photoURL is string) &&
             (data.uid == null || data.uid is string);
    }

    // --- Collection Rules ---

    match /test/connection {
      allow read: if true;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming()) && incoming().createdAt == request.time && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'category', 'images', 'sizes', 'gender', 'updatedAt']) &&
        incoming().createdAt == existing().createdAt
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow create: if isValidOrder(incoming()) && isValidId(orderId) &&
                    incoming().status == 'pending'; // New orders must be pending
      allow update: if isAdmin() && (
        // Admin actions: confirm, ship, deliver, cancel
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isSignedIn();
      allow create: if request.auth.token.email == "motaem23y@gmail.com" || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    isValidUser(incoming()) && (incoming().role == 'user' || isAdmin());
      allow update: if (isSignedIn() && request.auth.uid == userId && incoming().role == existing().role) || 
                    isAdmin();
      
      match /wishlist/{productId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /products/{productId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && 
                    incoming().rating >= 1 && incoming().rating <= 5;
      allow update, delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read: if true; // Notifications could be read by customers if they have the ID
      allow create: if isAdmin() && isValidId(notificationId);
      allow delete: if isAdmin();
    }

    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
