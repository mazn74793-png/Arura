rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validations ---

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.price is number && data.price > 0 &&
             data.category in ['pants', 'shirt', 'basic-tops'] &&
             data.images is list && data.images.size() > 0 &&
             data.sizes is list && data.sizes.size() > 0 &&
             data.gender in ['man', 'woman', 'unisex'];
    }

    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 &&
             data.phone is string && data.phone.size() >= 8 &&
             data.address is string && data.address.size() > 0 &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'confirmed', 'shipped', 'delivered', 'cancelled'];
    }

    // --- Collection Rules ---

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'category', 'images', 'sizes', 'gender'])
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin(); // Only admins read orders in this simplified version
      allow create: if isValidOrder(incoming()) && isValidId(orderId) &&
                    incoming().status == 'pending'; // New orders must be pending
      allow update: if isAdmin() && (
        // Admin actions: confirm, ship, deliver, cancel
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.token.email == "motaem23y@gmail.com" || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if true; // Notifications could be read by customers if they have the ID
      allow create: if isAdmin() && isValidId(notificationId);
      allow delete: if isAdmin();
    }

    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
